New Load.LD_19 bus1=19 phases=3 conn=wye model=1 kV=12.66 kW=90   kvar=40  Daily=LS_Load
New Load.LD_20 bus1=20 phases=3 conn=wye model=1 kV=12.66 kW=90   kvar=40  Daily=LS_Load
New Load.LD_21 bus1=21 phases=3 conn=wye model=1 kV=12.66 kW=90   kvar=40  Daily=LS_Load
New Load.LD_22 bus1=22 phases=3 conn=wye model=1 kV=12.66 kW=90   kvar=40  Daily=LS_Load
New Load.LD_23 bus1=23 phases=3 conn=wye model=1 kV=12.66 kW=90   kvar=50  Daily=LS_Load
New Load.LD_24 bus1=24 phases=3 conn=wye model=1 kV=12.66 kW=420  kvar=200 Daily=LS_Load
New Load.LD_25 bus1=25 phases=3 conn=wye model=1 kV=12.66 kW=420  kvar=200 Daily=LS_Load
New Load.LD_26 bus1=26 phases=3 conn=wye model=1 kV=12.66 kW=60   kvar=25  Daily=LS_Load
New Load.LD_27 bus1=27 phases=3 conn=wye model=1 kV=12.66 kW=60   kvar=25  Daily=LS_Load
New Load.LD_28 bus1=28 phases=3 conn=wye model=1 kV=12.66 kW=60   kvar=20  Daily=LS_Load
