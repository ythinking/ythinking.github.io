New Load.DG_20 bus1=20 phases=3 conn=wye model=1 kV=12.66 kW=-80  kvar=-49.5 Daily=LS_DG
New Load.DG_21 bus1=21 phases=3 conn=wye model=1 kV=12.66 kW=-80  kvar=-49.5 Daily=LS_DG

// ESS (charging positive; discharging negative via Loadshape multiplier sign)
New Load.ESS_8  bus1=8  phases=3 conn=wye model=1 kV=12.66 kW=200  kvar=123.8 Daily=LS_ESS
New Load.ESS_11 bus1=11 phases=3 conn=wye model=1 kV=12.66 kW=200  kvar=123.8 Daily=LS_ESS
