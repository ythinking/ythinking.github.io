New Load.LD_30 bus1=30 phases=3 conn=wye model=1 kV=12.66 kW=200  kvar=600 Daily=LS_Load
New Load.LD_31 bus1=31 phases=3 conn=wye model=1 kV=12.66 kW=150  kvar=70  Daily=LS_Load
New Load.LD_32 bus1=32 phases=3 conn=wye model=1 kV=12.66 kW=210  kvar=100 Daily=LS_Load
New Load.LD_33 bus1=33 phases=3 conn=wye model=1 kV=12.66 kW=60   kvar=40  Daily=LS_Load

// DER capacities (placeholders; you can modify freely later)
// PV: buses 7, 10, 24, 27 ; Pmax=100 kW each
// WT: buses 13, 30 ; Pmax=150 kW each
// DG: buses 2, 4, 16, 17, 20, 21 ; Pmax=80 kW each
// ESS: buses 8, 11, 32 ; Pmax=200 kW each, charging/discharging via LS_ESS
//
// Qmax = Pmax * 0.619

// PV (negative loads => injection)
New Load.PV_7  bus1=7  phases=3 conn=wye model=1 kV=12.66 kW=-100  kvar=-61.9 Daily=LS_PV
New Load.PV_10 bus1=10 phases=3 conn=wye model=1 kV=12.66 kW=-100  kvar=-61.9 Daily=LS_PV
New Load.PV_24 bus1=24 phases=3 conn=wye model=1 kV=12.66 kW=-100  kvar=-61.9 Daily=LS_PV
New Load.PV_27 bus1=27 phases=3 conn=wye model=1 kV=12.66 kW=-100  kvar=-61.9 Daily=LS_PV

// WT
New Load.WT_13 bus1=13 phases=3 conn=wye model=1 kV=12.66 kW=-150  kvar=-92.9 Daily=LS_WT
New Load.WT_30 bus1=30 phases=3 conn=wye model=1 kV=12.66 kW=-150  kvar=-92.9 Daily=LS_WT

// DG
New Load.DG_2  bus1=2  phases=3 conn=wye model=1 kV=12.66 kW=-80  kvar=-49.5 Daily=LS_DG
New Load.DG_4  bus1=4  phases=3 conn=wye model=1 kV=12.66 kW=-80  kvar=-49.5 Daily=LS_DG
New Load.DG_16 bus1=16 phases=3 conn=wye model=1 kV=12.66 kW=-80  kvar=-49.5 Daily=LS_DG
