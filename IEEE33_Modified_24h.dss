New Load.LD_15 bus1=15 phases=3 conn=wye model=1 kV=12.66 kW=60   kvar=10  Daily=LS_Load
New Load.LD_16 bus1=16 phases=3 conn=wye model=1 kV=12.66 kW=60   kvar=20  Daily=LS_Load
New Load.LD_17 bus1=17 phases=3 conn=wye model=1 kV=12.66 kW=60   kvar=20  Daily=LS_Load
